{
    "name": "@propelauth/node-apis",
    "repository": {
        "type": "git",
        "url": "https://github.com/PropelAuth/node-apis"
    },
    "version": "2.1.35",
    "license": "MIT",
    "keywords": [
        "auth",
        "node",
        "user"
    ],
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/node": "^20.19.39",
        "jest": "^29.7.0",
        "ts-jest": "^29.4.9",
        "tsup": "^7.2.0",
        "typescript": "^5.9.3"
    },
    "scripts": {
        "build": "npm run test && tsup",
        "dev": "tsup --watch",
        "prepublishOnly": "npm run build",
        "test": "jest --silent"
    },
    "files": [
        "dist"
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "browser": "./dist/index.mjs",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts",
            "default": "./dist/index.mjs"
        }
    },
    "typesVersions": {
        "*": {
            ".": [
                "./dist/index.d.ts"
            ]
        }
    },
    "jest": {
        "testMatch": [
            "**/test/*.ts"
        ],
        "moduleFileExtensions": [
            "ts",
            "js"
        ],
        "transform": {
            "^.+\\.(ts|tsx)?$": "ts-jest"
        }
    }
}
